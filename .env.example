POSTGRES_DB=bludm
POSTGRES_USER=bludm
POSTGRES_PASSWORD=change-this-postgres-password
WEB_PORT=3080

# DATABASE_URL can override the DATABASE_* settings below. Usually leave it blank in Docker.
DATABASE_URL=
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=bludm
DATABASE_USER=bludm
DATABASE_PASSWORD=change-this-postgres-password
DATABASE_SSLMODE=disable
SESSION_SECRET=change-this-to-a-long-random-session-secret-at-least-32-chars
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:3080
LOCAL_AUTH_ENABLED=true

# Local password registration. Leave enabled for self-host fallback accounts; disable only when
# OAuth is configured and you do not want username/password sign-up.
ADMIN_EMAIL=dm@example.test
ADMIN_PASSWORD=change-this-admin-password-at-least-12-chars

# Optional OAuth sign-in providers. Redirect URIs:
# Google: ${PUBLIC_APP_URL}/api/auth/google/callback
# Apple:  ${PUBLIC_APP_URL}/api/auth/apple/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
# Paste the PEM as a single env value with escaped newlines, or manage it in Portainer secrets/env.
OAUTH_APPLE_PRIVATE_KEY=

POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14
