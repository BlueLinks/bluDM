POSTGRES_DB=bludm
POSTGRES_USER=bludm
POSTGRES_PASSWORD=change-this-postgres-password
WEB_PORT=3080

# DATABASE_URL can override the DATABASE_* settings below. Usually leave it blank in Docker.
DATABASE_URL=
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=bludm
DATABASE_USER=bludm
DATABASE_PASSWORD=change-this-postgres-password
DATABASE_SSLMODE=disable
SESSION_SECRET=change-this-to-a-long-random-session-secret-at-least-32-chars
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:3080

ADMIN_EMAIL=dm@example.test
ADMIN_PASSWORD=change-this-admin-password-at-least-12-chars

POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14
