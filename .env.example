POSTGRES_DB=bludm
POSTGRES_USER=bludm
POSTGRES_PASSWORD=change-this-postgres-password
WEB_PORT=3000

DATABASE_URL=postgres://bludm:change-this-postgres-password@localhost:5432/bludm?sslmode=disable
SESSION_SECRET=change-this-to-a-long-random-session-secret
COOKIE_SECURE=false
PUBLIC_APP_URL=http://localhost:3000

ADMIN_EMAIL=dm@example.test
ADMIN_PASSWORD=change-this-admin-password

POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14
